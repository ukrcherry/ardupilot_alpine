#!/usr/bin/env bash
# =============================================================================
# config.env — Shared configuration for all ArduPilot/Alpine build scripts
# Source this from every other script: source "$(dirname "$0")/config.env"
# =============================================================================

# ---------- Version pins (change here to upgrade everything) -----------------
VER_GMP=6.3.0
VER_MPFR=4.2.1
VER_MPC=1.3.1
VER_ISL=0.26
VER_BINUTILS=2.40
VER_GCC=12.3.0
VER_NEWLIB=4.3.0
VER_CMAKE=3.28.3
VER_NINJA=1.11.1
VER_CCACHE=4.9.1
VER_PYTHON=3.11.9      # only if building Python from source (step optional)

# ---------- Toolchain target --------------------------------------------------
TARGET=arm-none-eabi

# ---------- Paths -------------------------------------------------------------
# All compiled artefacts live under AP_PREFIX so the whole tree is removable.
AP_PREFIX=/opt/ap-toolchain
AP_SRC=${AP_PREFIX}/src          # downloaded tarballs + build dirs
AP_LOG=${AP_PREFIX}/build.log    # global build log

# ArduPilot repo destination
ARDUPILOT_HOME=${HOME}/ardupilot

# ---------- Derived paths -----------------------------------------------------
TOOLCHAIN_BIN=${AP_PREFIX}/bin
TOOLCHAIN_ARM_BIN=${AP_PREFIX}/${TARGET}/bin   # not normally used standalone

# ---------- Parallelism -------------------------------------------------------
# Use all cores; override: export MAKE_JOBS=4
MAKE_JOBS="${MAKE_JOBS:-$(nproc)}"

# ---------- Environment applied to every build --------------------------------
export PATH="${TOOLCHAIN_BIN}:${PATH}"

# ---------- Colour helpers ---------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

# Ensure the prefix tree and log file exist before any logging.
# This is safe to run multiple times and works whether we are root or a
# normal user (00_bootstrap.sh runs as root, later scripts as a normal user).
mkdir -p "${AP_PREFIX}" "${AP_SRC}"
touch "${AP_LOG}" 2>/dev/null || true   # may fail if root hasn't run yet; that's fine
chmod 666 "${AP_LOG}" 2>/dev/null || true

# ---------------------------------------------------------------------------
# ALL log output goes to stderr so that command substitutions like
#   TARBALL=$(fetch "...")   or   SRC=$(extract_to "..." "name")
# capture ONLY the single echo'd return value on stdout, not log lines.
# Terminal output is preserved because stderr is visible on the console.
# ---------------------------------------------------------------------------
_log_write() {
    # Write message to stderr (terminal) and append to log file.
    echo -e "$1" >&2
    echo -e "$1" >> "${AP_LOG}" 2>/dev/null || true
}

log_info()  { _log_write "${CYAN}[INFO]${NC}  $*"; }
log_ok()    { _log_write "${GREEN}[ OK ]${NC}  $*"; }
log_warn()  { _log_write "${YELLOW}[WARN]${NC}  $*"; }
log_error() { _log_write "${RED}[ERR ]${NC}  $*"; exit 1; }

# Stamp a section header in the log
section() {
    _log_write ""
    _log_write "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    _log_write "${YELLOW}  $*${NC}"
    _log_write "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# Safe download: skip if tarball already exists.
# Usage:  TARBALL=$(fetch "https://...")
# Stdout: the local file path only.  All progress output goes to stderr.
fetch() {
    local url="$1"
    local dest="${AP_SRC}/$(basename "${url}")"
    if [[ -f "${dest}" ]]; then
        log_info "Already downloaded: $(basename "${url}")"
    else
        log_info "Downloading $(basename "${url}") ..."
        # wget progress goes to stderr; errors captured into log
        wget --progress=dot:giga -O "${dest}" "${url}" 2>&1 | tee -a "${AP_LOG}" >&2
    fi
    echo "${dest}"   # ← only this reaches stdout / command substitution
}

# Extract tarball to AP_SRC; skip if target directory already exists.
# Usage:  SRC_DIR=$(extract_to "/path/to/foo.tar.xz" "foo-1.2.3")
# Stdout: the extracted directory path only.
extract_to() {
    local tarball="$1"
    local dir_name="$2"
    local target="${AP_SRC}/${dir_name}"
    if [[ -d "${target}" ]]; then
        log_info "Already extracted: ${dir_name}"
    else
        log_info "Extracting $(basename "${tarball}") ..."
        tar -xf "${tarball}" -C "${AP_SRC}" 2>&1 | tee -a "${AP_LOG}" >&2
    fi
    echo "${target}"   # ← only this reaches stdout / command substitution
}

# Build in a separate _build sub-directory (GCC requirement); skip if stamp present.
# Usage:  BUILD_DIR=$(build_in_subdir "/path/to/src")
# Returns the _build path on stdout; if already done returns "" (caller checks stamp).
build_in_subdir() {
    local src_dir="$1"
    local stamp="${src_dir}/_build/.install_done"
    if [[ -f "${stamp}" ]]; then
        log_info "Already built: $(basename "${src_dir}")"
        echo ""   # caller must check for empty string
        return 0
    fi
    mkdir -p "${src_dir}/_build"
    echo "${src_dir}/_build"   # ← only this reaches stdout
}

require_cmd() {
    command -v "$1" &>/dev/null || log_error "Required command '$1' not found. Run 00_bootstrap.sh first."
}
