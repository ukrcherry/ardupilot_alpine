#!/usr/bin/env bash
# =============================================================================
# config.env — Shared configuration for all ArduPilot/Alpine build scripts
# Source this from every other script: source "$(dirname "$0")/config.env"
# =============================================================================

# ---------- Version pins (change here to upgrade everything) -----------------
VER_GMP=6.3.0
VER_MPFR=4.2.1
VER_MPC=1.3.1
VER_ISL=0.26
VER_BINUTILS=2.40
VER_GCC=12.3.0
VER_NEWLIB=4.3.0
VER_CMAKE=3.28.3
VER_NINJA=1.11.1
VER_CCACHE=4.9.1
VER_PYTHON=3.11.9      # only if building Python from source (step optional)

# ---------- Toolchain target --------------------------------------------------
TARGET=arm-none-eabi

# ---------- Paths -------------------------------------------------------------
# All compiled artefacts live under AP_PREFIX so the whole tree is removable.
AP_PREFIX=/opt/ap-toolchain
AP_SRC=${AP_PREFIX}/src          # downloaded tarballs + build dirs
AP_LOG=${AP_PREFIX}/build.log    # global build log

# ArduPilot repo destination
ARDUPILOT_HOME=${HOME}/ardupilot

# ---------- Derived paths -----------------------------------------------------
TOOLCHAIN_BIN=${AP_PREFIX}/bin
TOOLCHAIN_ARM_BIN=${AP_PREFIX}/${TARGET}/bin   # not normally used standalone

# ---------- Parallelism -------------------------------------------------------
# Use all cores; override: export MAKE_JOBS=4
MAKE_JOBS="${MAKE_JOBS:-$(nproc)}"

# ---------- Environment applied to every build --------------------------------
export PATH="${TOOLCHAIN_BIN}:${PATH}"

# ---------- Colour helpers ---------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'

log_info()  { echo -e "${CYAN}[INFO]${NC}  $*" | tee -a "${AP_LOG}"; }
log_ok()    { echo -e "${GREEN}[ OK ]${NC}  $*" | tee -a "${AP_LOG}"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*" | tee -a "${AP_LOG}"; }
log_error() { echo -e "${RED}[ERR ]${NC}  $*" | tee -a "${AP_LOG}"; exit 1; }

# Stamp a section header in the log
section() {
    echo "" | tee -a "${AP_LOG}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}" | tee -a "${AP_LOG}"
    echo -e "${YELLOW}  $*${NC}" | tee -a "${AP_LOG}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}" | tee -a "${AP_LOG}"
}

# Safe download: skip if tarball already exists
fetch() {
    local url="$1"
    local dest="${AP_SRC}/$(basename "${url}")"
    if [[ -f "${dest}" ]]; then
        log_info "Already downloaded: $(basename "${url}")"
    else
        log_info "Downloading $(basename "${url}") ..."
        wget --progress=dot:giga -O "${dest}" "${url}" 2>&1 | tee -a "${AP_LOG}"
    fi
    echo "${dest}"          # return the path
}

# Extract tarball to AP_SRC, skip if directory already present
extract_to() {
    local tarball="$1"
    local dir_name="$2"     # expected directory name after extraction
    local target="${AP_SRC}/${dir_name}"
    if [[ -d "${target}" ]]; then
        log_info "Already extracted: ${dir_name}"
    else
        log_info "Extracting ${tarball} ..."
        tar -xf "${tarball}" -C "${AP_SRC}" 2>&1 | tee -a "${AP_LOG}"
    fi
    echo "${target}"        # return the path
}

# Build in a separate _build sub-directory (GCC requirement); skip if stamp present
build_in_subdir() {
    local src_dir="$1"      # absolute path to source tree
    local stamp="${src_dir}/_build/.install_done"
    if [[ -f "${stamp}" ]]; then
        log_info "Already built: $(basename "${src_dir}")"
        return 0
    fi
    mkdir -p "${src_dir}/_build"
    echo "${src_dir}/_build"   # caller: BUILD=$(build_in_subdir ...)
}

require_cmd() {
    command -v "$1" &>/dev/null || log_error "Required command '$1' not found. Run 00_bootstrap.sh first."
}
